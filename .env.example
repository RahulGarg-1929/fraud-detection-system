# ============================================================
# Fraud Detection System — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# Never commit the .env file to version control.
# ============================================================

# ── API Server ───────────────────────────────────────────────
# Host and port for the FastAPI backend
API_HOST=0.0.0.0
API_PORT=8000

# Deployment environment: development | staging | production
ENVIRONMENT=development

# ── Frontend ─────────────────────────────────────────────────
# Base URL of the backend API consumed by the React frontend.
# Local: http://localhost:8000
# Production: your Railway app URL, e.g. https://fraud-api.railway.app
VITE_API_URL=http://localhost:8000

# ── Model ────────────────────────────────────────────────────
# Name of the model file (without extension) to load at startup.
# Available: lightgbm_best | xgboost_best | random_forest | logistic_regression
MODEL_NAME=lightgbm_best

# Default fraud-probability decision threshold (0.0–1.0).
# Overridden by the optimal threshold stored in models/optimal_thresholds.pkl.
DEFAULT_THRESHOLD=0.5

# ── Security ─────────────────────────────────────────────────
# Secret key used for signing tokens / sessions (generate a strong random string).
# Example: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Comma-separated list of allowed CORS origins for the API.
# Use * only during local development.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Logging ──────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Railway (CI/CD secrets — set in GitHub repository settings) ───
# RAILWAY_TOKEN=                  # Railway API token (keep secret!)

# ── Vercel (CI/CD secrets — set in GitHub repository settings) ────
# VERCEL_TOKEN=                   # Vercel API token (keep secret!)
# VERCEL_ORG_ID=                  # Vercel organisation / personal account ID
# VERCEL_PROJECT_ID=              # Vercel project ID for the frontend
